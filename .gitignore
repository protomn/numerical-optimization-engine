# ==============================================================
# C++ build artifacts
# ==============================================================

# Object files
*.o
*.obj

# Static / shared libraries
*.a
*.lib
*.so
*.so.*
*.dylib
*.dll

# Precompiled headers
*.gch
*.pch

# Dependency files generated by -MMD/-MP
*.d

# Build and binary output directories
/build/
/bin/

# CMake (if ever added)
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile.cmake

# ==============================================================
# Python
# ==============================================================

# Byte-compiled / optimised / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyd

# Distribution / packaging
dist/
build/
eggs/
*.egg-info/
*.egg
.eggs/
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/
.env

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/

# Jupyter
.ipynb_checkpoints/

# mypy / pyright type checker caches
.mypy_cache/
.pyright/
.ruff_cache/

# ==============================================================
# OS & editor noise
# ==============================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# VS Code
.vscode/

# CLion / JetBrains
.idea/
cmake-build-*/

# Vim / Emacs swap files
*.swp
*.swo
*~
